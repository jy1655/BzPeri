/* Configuration header for BzPeri */

#ifndef CONFIG_H
#define CONFIG_H

/* Project version */
#cmakedefine PROJECT_VERSION "@PROJECT_VERSION@"

/* Define if std::format is available */
#cmakedefine HAS_STD_FORMAT @HAS_STD_FORMAT@

/* Platform definitions */
#cmakedefine PLATFORM_LINUX
#cmakedefine PLATFORM_MACOS
#cmakedefine NO_GLIB

/* Debug mode */
#cmakedefine DEBUG

/* Default GLib log capture mode: 0=AUTOMATIC, 1=DISABLED, 2=HOST_MANAGED, 3=STARTUP_AND_SHUTDOWN */
#define BZP_DEFAULT_GLIB_LOG_CAPTURE_MODE_VALUE @BZP_DEFAULT_GLIB_LOG_CAPTURE_MODE_VALUE@

/* Default GLib log capture targets bitmask: 1=PRINT, 2=PRINTERR, 4=LOG */
#define BZP_DEFAULT_GLIB_LOG_CAPTURE_TARGETS_VALUE @BZP_DEFAULT_GLIB_LOG_CAPTURE_TARGETS_VALUE@

/* Default GLib log capture domains bitmask: 1=DEFAULT, 2=GLIB, 4=GIO, 8=BLUEZ, 16=OTHER */
#define BZP_DEFAULT_GLIB_LOG_CAPTURE_DOMAINS_VALUE @BZP_DEFAULT_GLIB_LOG_CAPTURE_DOMAINS_VALUE@

#endif /* CONFIG_H */
